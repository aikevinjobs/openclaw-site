---
import BaseLayout from "../../components/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Download OpenClaw" description="Install OpenClaw AI agent with one command. Supports macOS, Linux, and Windows." lang="en">
  <Navbar lang="en" />

  <section class="pt-32 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl font-bold text-center mb-4">Get Started with OpenClaw</h1>
      <p class="text-gray-400 text-center mb-12">3 steps to launch your AI agent</p>

      <!-- Step 1: Download & Install -->
      <div class="mb-8">
        <div class="p-6 rounded-xl bg-white/5 border border-white/10">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold">1</span>
            <div class="flex-1">
              <h2 class="text-xl font-semibold mb-2">Download & Install</h2>
              <p class="text-sm text-gray-400 mb-4">Choose your platform and install</p>

              <!-- Auto detect -->
              <div class="text-center mb-6 p-4 rounded-lg bg-white/5 border border-white/10">
                <p class="text-xs text-gray-400 mb-2">Detected OS: <span id="detected-os" class="text-white font-semibold">Detecting...</span></p>
                <div class="install-cmd max-w-xl mx-auto mt-2" id="auto-cmd" onclick="navigator.clipboard.writeText(this.textContent.trim())">
                  npm install -g openclaw
                </div>
              </div>

              <!-- Platform tabs -->
              <div class="space-y-4">
                <details class="group">
                  <summary class="flex items-center gap-3 cursor-pointer text-gray-300 hover:text-white transition-colors">
                    <span class="text-lg">🍎</span>
                    <span class="font-medium">macOS</span>
                    <svg class="w-4 h-4 ml-auto transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="mt-3 ml-8 space-y-3">
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">Desktop App (Recommended)</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('brew install --cask openclaw')">brew install --cask openclaw</div>
                    </div>
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">CLI</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('npm install -g openclaw')">npm install -g openclaw</div>
                    </div>
                  </div>
                </details>

                <details class="group">
                  <summary class="flex items-center gap-3 cursor-pointer text-gray-300 hover:text-white transition-colors">
                    <span class="text-lg">🐧</span>
                    <span class="font-medium">Linux</span>
                    <svg class="w-4 h-4 ml-auto transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="mt-3 ml-8 space-y-3">
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">Install Script (Recommended)</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('curl -fsSL https://openclaw.ai/install.sh | bash')">curl -fsSL https://openclaw.ai/install.sh | bash</div>
                    </div>
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">Docker</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('docker run -d --name openclaw openclaw/openclaw')">docker run -d --name openclaw openclaw/openclaw</div>
                    </div>
                  </div>
                </details>

                <details class="group">
                  <summary class="flex items-center gap-3 cursor-pointer text-gray-300 hover:text-white transition-colors">
                    <span class="text-lg">🪟</span>
                    <span class="font-medium">Windows</span>
                    <svg class="w-4 h-4 ml-auto transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="mt-3 ml-8 space-y-3">
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">npm</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('npm install -g openclaw')">npm install -g openclaw</div>
                    </div>
                    <div>
                      <span class="text-xs text-gray-500 mb-1 block">PowerShell</span>
                      <div class="install-cmd" onclick="navigator.clipboard.writeText('irm https://openclaw.ai/install.ps1 | iex')">irm https://openclaw.ai/install.ps1 | iex</div>
                    </div>
                  </div>
                </details>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Recharge -->
      <div class="mb-8">
        <div class="p-6 rounded-xl bg-indigo-600/10 border border-indigo-500/30">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-indigo-600 text-white flex items-center justify-center text-sm font-bold">2</span>
            <div class="flex-1">
              <h2 class="text-xl font-semibold mb-2">Top Up Your Account</h2>
              <p class="text-sm text-gray-400 mb-4">
                Top up <strong class="text-indigo-400">¥6</strong> to get AI tokens + free cloud deployment. No API keys or model config needed.
              </p>
              <a href="/en/recharge/" class="inline-block px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white font-semibold transition-colors">
                Top Up ¥6
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Start & Connect -->
      <div class="mb-8">
        <div class="p-6 rounded-xl bg-white/5 border border-white/10">
          <div class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-white/10 text-gray-300 flex items-center justify-center text-sm font-bold">3</span>
            <div class="flex-1">
              <h2 class="text-xl font-semibold mb-2">Start & Connect</h2>
              <p class="text-sm text-gray-400 mb-3">Start the gateway:</p>
              <div class="install-cmd" onclick="navigator.clipboard.writeText('openclaw gateway run')">openclaw gateway run</div>
              <p class="text-sm text-gray-400 mt-4 mb-3">Connect your first chat platform (e.g. Telegram):</p>
              <div class="install-cmd" onclick="navigator.clipboard.writeText('openclaw channels add telegram')">openclaw channels add telegram</div>
              <p class="text-sm text-gray-400 mt-4">Once connected, send a message to your bot and start chatting.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />

  <script>
    const ua = navigator.userAgent;
    const osEl = document.getElementById("detected-os");
    const cmdEl = document.getElementById("auto-cmd");
    if (ua.includes("Mac")) {
      if (osEl) osEl.textContent = "macOS";
      if (cmdEl) cmdEl.textContent = "brew install --cask openclaw";
    } else if (ua.includes("Win")) {
      if (osEl) osEl.textContent = "Windows";
      if (cmdEl) cmdEl.textContent = "npm install -g openclaw";
    } else if (ua.includes("Linux")) {
      if (osEl) osEl.textContent = "Linux";
      if (cmdEl) cmdEl.textContent = "curl -fsSL https://openclaw.ai/install.sh | bash";
    } else {
      if (osEl) osEl.textContent = "npm (universal)";
    }
  </script>
</BaseLayout>
