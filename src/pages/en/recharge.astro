---
import BaseLayout from "../../components/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Recharge - OpenClaw" description="Top up your OpenClaw account to connect AI models and start using agent services." lang="en">
  <Navbar lang="en" />

  <section class="pt-32 pb-20 px-4">
    <div class="max-w-xl mx-auto">
      <h1 class="text-3xl font-bold text-center mb-2">Account Top-up</h1>
      <p class="text-gray-400 text-center mb-8">Top up to connect AI models and start using OpenClaw</p>

      <!-- Balance display -->
      <div class="p-4 rounded-xl bg-white/5 border border-white/10 mb-8 flex items-center justify-between">
        <span class="text-sm text-gray-400">Current Balance</span>
        <span class="text-2xl font-bold text-indigo-400" id="balance">--</span>
      </div>

      <!-- Amount selection -->
      <div class="mb-6">
        <label class="block text-sm text-gray-300 mb-3">Select Amount</label>
        <div class="grid grid-cols-3 gap-3" id="amount-grid">
          <button class="amount-btn" data-amount="6">
            <span class="text-lg font-bold">¥6</span>
            <span class="text-xs text-gray-400">Recommended</span>
          </button>
          <button class="amount-btn" data-amount="10">
            <span class="text-lg font-bold">¥10</span>
          </button>
          <button class="amount-btn" data-amount="20">
            <span class="text-lg font-bold">¥20</span>
          </button>
          <button class="amount-btn" data-amount="50">
            <span class="text-lg font-bold">¥50</span>
          </button>
          <button class="amount-btn" data-amount="100">
            <span class="text-lg font-bold">¥100</span>
          </button>
          <button class="amount-btn" data-amount="custom" id="custom-btn">
            <span class="text-sm">Custom</span>
          </button>
        </div>
        <div class="mt-3 hidden" id="custom-input-wrap">
          <div class="flex items-center gap-2">
            <span class="text-gray-400">¥</span>
            <input
              type="number"
              id="custom-amount"
              min="1"
              step="1"
              placeholder="Enter amount (min ¥1)"
              class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500"
            />
          </div>
        </div>
      </div>

      <!-- Payment method -->
      <div class="mb-8">
        <label class="block text-sm text-gray-300 mb-3">Payment Method</label>
        <div class="grid grid-cols-2 gap-3" id="pay-method-grid">
          <button class="pay-method-btn selected" data-method="alipay">
            <span class="text-lg">💳</span>
            <span class="text-sm">Alipay</span>
          </button>
          <button class="pay-method-btn" data-method="wechat">
            <span class="text-lg">💚</span>
            <span class="text-sm">WeChat Pay</span>
          </button>
        </div>
      </div>

      <!-- Submit -->
      <button
        id="submit-btn"
        class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white font-semibold transition-colors text-lg disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Top Up ¥<span id="submit-amount">6</span>
      </button>

      <p class="text-xs text-gray-500 text-center mt-4">
        You will be redirected to a secure payment page. Balance will update automatically after payment.
      </p>

      <!-- Recharge history -->
      <div class="mt-12">
        <h2 class="text-lg font-semibold mb-4">Transaction History</h2>
        <div id="history-list" class="space-y-2">
          <p class="text-sm text-gray-500" id="history-empty">Log in to view transaction history</p>
        </div>
      </div>
    </div>
  </section>

  <Footer lang="en" />

  <style>
    .amount-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      padding: 0.75rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      color: white;
      cursor: pointer;
      transition: all 0.2s;
    }
    .amount-btn:hover {
      border-color: rgba(99, 102, 241, 0.5);
      background: rgba(99, 102, 241, 0.1);
    }
    .amount-btn.selected {
      border-color: #6366f1;
      background: rgba(99, 102, 241, 0.2);
      box-shadow: 0 0 0 1px #6366f1;
    }
    .pay-method-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.05);
      color: white;
      cursor: pointer;
      transition: all 0.2s;
    }
    .pay-method-btn:hover {
      border-color: rgba(99, 102, 241, 0.5);
    }
    .pay-method-btn.selected {
      border-color: #6366f1;
      background: rgba(99, 102, 241, 0.2);
      box-shadow: 0 0 0 1px #6366f1;
    }
    .pay-method-btn.disabled {
      opacity: 0.3;
      cursor: not-allowed;
      pointer-events: none;
    }
  </style>

  <script>
    const PAYMENT_DOMAIN = "https://www.wensiwanxiang.com";
    const API_BASE = PAYMENT_DOMAIN + "/api";
    const RETURN_URL = "https://openclaw.cooking/pay-success";

    let selectedAmount = 6;
    let paymentMethod = "alipay";

    const ua = navigator.userAgent;
    const isWeChat = /MicroMessenger/i.test(ua);
    const isMobile = /mobile|android|iphone|ipad|phone/i.test(ua);

    const alipayBtn = document.querySelector('[data-method="alipay"]') as HTMLElement;
    const wechatBtn = document.querySelector('[data-method="wechat"]') as HTMLElement;

    if (isWeChat) {
      paymentMethod = "wechat";
      alipayBtn?.classList.add("disabled");
      alipayBtn?.classList.remove("selected");
      wechatBtn?.classList.add("selected");
    } else if (isMobile) {
      wechatBtn?.classList.add("disabled");
    }

    function getUserId(): string {
      const params = new URLSearchParams(window.location.search);
      return params.get("userId") || localStorage.getItem("openclaw_userId") || "";
    }

    async function fetchBalance() {
      const userId = getUserId();
      if (!userId) return;
      try {
        const res = await fetch(`${API_BASE}/user/balance?userId=${encodeURIComponent(userId)}`);
        const data = await res.json();
        if (data.success && data.data) {
          const el = document.getElementById("balance");
          if (el) el.textContent = `¥${Number(data.data.balance).toFixed(2)}`;
        }
      } catch {
        // silently fail
      }
    }

    async function fetchHistory() {
      const userId = getUserId();
      if (!userId) return;
      try {
        const res = await fetch(`${API_BASE}/user/recharge-history?userId=${encodeURIComponent(userId)}&page=1&pageSize=10`);
        const data = await res.json();
        if (data.success && data.data?.records?.length) {
          const list = document.getElementById("history-list");
          const empty = document.getElementById("history-empty");
          if (empty) empty.style.display = "none";
          if (list) {
            data.data.records.forEach((r: { orderNo: string; amount: number; status: string; createdAt: string }) => {
              const item = document.createElement("div");
              item.className = "flex items-center justify-between p-3 rounded-lg bg-white/5 text-sm";
              item.innerHTML = `
                <div>
                  <span class="text-gray-300">¥${Number(r.amount).toFixed(2)}</span>
                  <span class="ml-2 text-xs ${r.status === 'success' ? 'text-green-400' : 'text-yellow-400'}">${r.status === 'success' ? 'Success' : 'Pending'}</span>
                </div>
                <span class="text-xs text-gray-500">${new Date(r.createdAt).toLocaleDateString()}</span>
              `;
              list.appendChild(item);
            });
          }
        }
      } catch {
        // silently fail
      }
    }

    document.querySelectorAll(".amount-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".amount-btn").forEach((b) => b.classList.remove("selected"));
        btn.classList.add("selected");

        const amount = (btn as HTMLElement).dataset.amount;
        const customWrap = document.getElementById("custom-input-wrap");

        if (amount === "custom") {
          customWrap?.classList.remove("hidden");
          const input = document.getElementById("custom-amount") as HTMLInputElement;
          input?.focus();
        } else {
          customWrap?.classList.add("hidden");
          selectedAmount = Number(amount);
          updateSubmitAmount();
        }
      });
    });

    const customInput = document.getElementById("custom-amount") as HTMLInputElement;
    customInput?.addEventListener("input", () => {
      const val = Number(customInput.value);
      if (val >= 1) {
        selectedAmount = val;
        updateSubmitAmount();
      }
    });

    document.querySelectorAll(".pay-method-btn:not(.disabled)").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".pay-method-btn").forEach((b) => b.classList.remove("selected"));
        btn.classList.add("selected");
        paymentMethod = (btn as HTMLElement).dataset.method || "alipay";
      });
    });

    function updateSubmitAmount() {
      const el = document.getElementById("submit-amount");
      if (el) el.textContent = String(selectedAmount);
    }

    document.getElementById("submit-btn")?.addEventListener("click", () => {
      const userId = getUserId();
      if (!userId) {
        alert("Please log in before topping up");
        return;
      }
      if (selectedAmount < 1) {
        alert("Minimum top-up amount is ¥1");
        return;
      }

      localStorage.setItem("openclaw_userId", userId);

      const params = new URLSearchParams({
        amount: String(selectedAmount),
        paymentMethod,
        userId,
        returnUrl: RETURN_URL,
      });

      window.location.href = `${PAYMENT_DOMAIN}/orderConfirm?${params.toString()}`;
    });

    document.querySelector('[data-amount="6"]')?.classList.add("selected");
    updateSubmitAmount();

    fetchBalance();
    fetchHistory();
  </script>
</BaseLayout>
