---
import BaseLayout from "../components/BaseLayout.astro";
---

<BaseLayout title="控制台 - OpenClaw" description="OpenClaw 用户控制台，管理你的 AI 智能体。" lang="zh-CN">

  <!-- Navbar (simplified for dashboard) -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-gray-950/80 border-b border-white/10">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight">
        <span class="text-indigo-400">Open</span><span class="text-white">Claw</span>
        <span class="text-xs text-gray-500 ml-2">控制台</span>
      </a>
      <div class="flex items-center gap-3">
        <span class="text-sm text-gray-400" id="nav-phone"></span>
        <button id="logout-btn" class="text-xs px-2 py-1 rounded border border-white/20 text-gray-400 hover:text-white transition-colors hidden">
          退出
        </button>
      </div>
    </div>
  </nav>

  <!-- Login Screen -->
  <section id="login-screen" class="pt-24 pb-20 px-4">
    <div class="max-w-sm mx-auto">
      <h1 class="text-2xl font-bold text-center mb-2">登录 OpenClaw</h1>
      <p class="text-gray-400 text-center text-sm mb-8">输入手机号即可开始</p>

      <div class="space-y-4">
        <div>
          <input
            type="tel"
            id="phone-input"
            placeholder="请输入手机号"
            maxlength="11"
            class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500 text-center text-lg tracking-widest"
          />
        </div>
        <div class="flex gap-2">
          <input
            type="text"
            id="code-input"
            placeholder="验证码"
            maxlength="6"
            class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500 text-center text-lg tracking-widest"
          />
          <button
            id="send-code-btn"
            class="px-4 py-3 bg-white/10 hover:bg-white/15 rounded-lg text-sm text-gray-300 transition-colors whitespace-nowrap"
          >
            获取验证码
          </button>
        </div>
        <button
          id="login-btn"
          class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white font-semibold transition-colors"
        >
          登录
        </button>
      </div>

      <p class="text-xs text-gray-500 text-center mt-4">首次登录自动注册，登录即同意服务条款</p>
    </div>
  </section>

  <!-- Dashboard Screen -->
  <section id="dashboard-screen" class="pt-20 pb-20 px-4 hidden">
    <div class="max-w-2xl mx-auto space-y-6">

      <!-- Balance Card -->
      <div class="p-6 rounded-xl bg-gradient-to-r from-indigo-600/20 to-purple-600/20 border border-indigo-500/30">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm text-gray-400">账户余额</span>
          <span class="text-xs text-gray-500" id="dash-phone"></span>
        </div>
        <div class="flex items-end justify-between">
          <span class="text-4xl font-bold text-white" id="dash-balance">¥0.00</span>
          <button
            id="recharge-btn"
            class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white text-sm font-semibold transition-colors"
          >
            充值
          </button>
        </div>
      </div>

      <!-- Quick Recharge -->
      <div class="p-5 rounded-xl bg-white/5 border border-white/10">
        <h2 class="text-sm font-semibold text-gray-300 mb-3">快捷充值</h2>
        <div class="grid grid-cols-5 gap-2" id="quick-amounts">
          <button class="quick-amt selected" data-amount="6">¥6</button>
          <button class="quick-amt" data-amount="10">¥10</button>
          <button class="quick-amt" data-amount="20">¥20</button>
          <button class="quick-amt" data-amount="50">¥50</button>
          <button class="quick-amt" data-amount="100">¥100</button>
        </div>
        <div class="flex gap-2 mt-3">
          <button id="pay-alipay" class="flex-1 py-2.5 bg-blue-600/20 hover:bg-blue-600/30 border border-blue-500/30 rounded-lg text-sm text-blue-300 transition-colors">
            支付宝支付
          </button>
          <button id="pay-wechat" class="flex-1 py-2.5 bg-green-600/20 hover:bg-green-600/30 border border-green-500/30 rounded-lg text-sm text-green-300 transition-colors">
            微信支付
          </button>
        </div>
      </div>

      <!-- AI Status -->
      <div class="p-5 rounded-xl bg-white/5 border border-white/10">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-gray-300">AI 智能体状态</h2>
          <span class="text-xs px-2 py-0.5 rounded-full" id="agent-status-badge">检测中...</span>
        </div>
        <div class="text-sm text-gray-400" id="agent-status-text">
          正在检查你的智能体运行状态...
        </div>
      </div>

      <!-- Connected Channels -->
      <div class="p-5 rounded-xl bg-white/5 border border-white/10">
        <h2 class="text-sm font-semibold text-gray-300 mb-4">消息渠道</h2>
        <p class="text-xs text-gray-500 mb-4">开启后，你可以在对应平台上与 AI 智能体对话</p>
        <div class="space-y-3" id="channels-list">

          <div class="channel-item" data-channel="wechat">
            <div class="flex items-center gap-3">
              <span class="text-lg">💚</span>
              <div class="flex-1">
                <span class="text-sm text-white">微信</span>
                <p class="text-xs text-gray-500">扫码绑定你的微信</p>
              </div>
              <button class="channel-toggle" data-channel="wechat">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="telegram">
            <div class="flex items-center gap-3">
              <span class="text-lg">✈️</span>
              <div class="flex-1">
                <span class="text-sm text-white">Telegram</span>
                <p class="text-xs text-gray-500">填入 Bot Token 即可</p>
              </div>
              <button class="channel-toggle" data-channel="telegram">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="dingtalk">
            <div class="flex items-center gap-3">
              <span class="text-lg">📌</span>
              <div class="flex-1">
                <span class="text-sm text-white">钉钉</span>
                <p class="text-xs text-gray-500">企业内部机器人</p>
              </div>
              <button class="channel-toggle" data-channel="dingtalk">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="feishu">
            <div class="flex items-center gap-3">
              <span class="text-lg">🐦</span>
              <div class="flex-1">
                <span class="text-sm text-white">飞书</span>
                <p class="text-xs text-gray-500">飞书自建应用</p>
              </div>
              <button class="channel-toggle" data-channel="feishu">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="wecom">
            <div class="flex items-center gap-3">
              <span class="text-lg">🏢</span>
              <div class="flex-1">
                <span class="text-sm text-white">企业微信</span>
                <p class="text-xs text-gray-500">企业微信应用</p>
              </div>
              <button class="channel-toggle" data-channel="wecom">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="discord">
            <div class="flex items-center gap-3">
              <span class="text-lg">🎮</span>
              <div class="flex-1">
                <span class="text-sm text-white">Discord</span>
                <p class="text-xs text-gray-500">Discord Bot</p>
              </div>
              <button class="channel-toggle" data-channel="discord">配置</button>
            </div>
          </div>

          <div class="channel-item" data-channel="whatsapp">
            <div class="flex items-center gap-3">
              <span class="text-lg">📱</span>
              <div class="flex-1">
                <span class="text-sm text-white">WhatsApp</span>
                <p class="text-xs text-gray-500">WhatsApp Business</p>
              </div>
              <button class="channel-toggle" data-channel="whatsapp">配置</button>
            </div>
          </div>

        </div>
      </div>

      <!-- Channel Config Modal (hidden by default) -->
      <div id="channel-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
        <div class="bg-gray-900 border border-white/10 rounded-xl p-6 max-w-md w-full mx-4">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold" id="modal-title">配置渠道</h3>
            <button id="modal-close" class="text-gray-400 hover:text-white text-xl">&times;</button>
          </div>
          <div id="modal-body" class="space-y-4">
            <!-- Dynamic content -->
          </div>
          <div class="flex gap-3 mt-6">
            <button id="modal-cancel" class="flex-1 py-2 border border-white/10 rounded-lg text-sm text-gray-400 hover:text-white transition-colors">取消</button>
            <button id="modal-save" class="flex-1 py-2 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-sm text-white font-semibold transition-colors">保存</button>
          </div>
        </div>
      </div>

      <!-- Usage History -->
      <div class="p-5 rounded-xl bg-white/5 border border-white/10">
        <h2 class="text-sm font-semibold text-gray-300 mb-3">最近使用</h2>
        <div id="usage-list" class="space-y-2">
          <p class="text-xs text-gray-500">暂无使用记录</p>
        </div>
      </div>

    </div>
  </section>

  <style>
    .quick-amt {
      padding: 0.5rem;
      border-radius: 0.5rem;
      border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05);
      color: white;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .quick-amt:hover { border-color: rgba(99,102,241,0.5); }
    .quick-amt.selected {
      border-color: #6366f1;
      background: rgba(99,102,241,0.2);
      box-shadow: 0 0 0 1px #6366f1;
    }
    .channel-item {
      padding: 0.75rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(255,255,255,0.05);
      background: rgba(255,255,255,0.02);
      transition: background 0.2s;
    }
    .channel-item:hover { background: rgba(255,255,255,0.05); }
    .channel-toggle {
      padding: 0.25rem 0.75rem;
      border-radius: 0.5rem;
      border: 1px solid rgba(255,255,255,0.15);
      background: transparent;
      color: #9ca3af;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .channel-toggle:hover { border-color: #6366f1; color: white; }
    .channel-toggle.active {
      background: rgba(34,197,94,0.15);
      border-color: rgba(34,197,94,0.4);
      color: #4ade80;
    }
  </style>

  <script>
    const API_BASE = "https://www.wensiwanxiang.com/api";
    const PAYMENT_DOMAIN = "https://www.wensiwanxiang.com";
    const RETURN_URL = "https://openclaw.cooking/pay-success";

    // --- State ---
    let userId = localStorage.getItem("openclaw_userId") || "";
    let selectedAmount = 6;

    // --- DOM ---
    const loginScreen = document.getElementById("login-screen")!;
    const dashScreen = document.getElementById("dashboard-screen")!;
    const phoneInput = document.getElementById("phone-input") as HTMLInputElement;
    const codeInput = document.getElementById("code-input") as HTMLInputElement;
    const sendCodeBtn = document.getElementById("send-code-btn")!;
    const loginBtn = document.getElementById("login-btn")!;
    const logoutBtn = document.getElementById("logout-btn")!;
    const navPhone = document.getElementById("nav-phone")!;
    const dashPhone = document.getElementById("dash-phone")!;
    const dashBalance = document.getElementById("dash-balance")!;

    // --- Channel Config Data ---
    const channelConfigs: Record<string, { title: string; fields: { key: string; label: string; placeholder: string }[] }> = {
      wechat: {
        title: "配置微信",
        fields: [
          { key: "appId", label: "AppID", placeholder: "微信公众号 AppID" },
          { key: "appSecret", label: "AppSecret", placeholder: "微信公众号 AppSecret" },
        ],
      },
      telegram: {
        title: "配置 Telegram",
        fields: [
          { key: "botToken", label: "Bot Token", placeholder: "从 @BotFather 获取的 Token" },
        ],
      },
      dingtalk: {
        title: "配置钉钉",
        fields: [
          { key: "appKey", label: "AppKey", placeholder: "钉钉应用 AppKey" },
          { key: "appSecret", label: "AppSecret", placeholder: "钉钉应用 AppSecret" },
        ],
      },
      feishu: {
        title: "配置飞书",
        fields: [
          { key: "appId", label: "App ID", placeholder: "飞书应用 App ID" },
          { key: "appSecret", label: "App Secret", placeholder: "飞书应用 App Secret" },
        ],
      },
      wecom: {
        title: "配置企业微信",
        fields: [
          { key: "corpId", label: "Corp ID", placeholder: "企业微信 Corp ID" },
          { key: "agentId", label: "Agent ID", placeholder: "应用 Agent ID" },
          { key: "secret", label: "Secret", placeholder: "应用 Secret" },
        ],
      },
      discord: {
        title: "配置 Discord",
        fields: [
          { key: "botToken", label: "Bot Token", placeholder: "Discord Bot Token" },
        ],
      },
      whatsapp: {
        title: "配置 WhatsApp",
        fields: [
          { key: "phoneNumberId", label: "Phone Number ID", placeholder: "WhatsApp Business Phone Number ID" },
          { key: "accessToken", label: "Access Token", placeholder: "Meta Graph API Token" },
        ],
      },
    };

    // --- Login / Auth ---
    function maskPhone(phone: string) {
      if (phone.length >= 7) return phone.slice(0, 3) + "****" + phone.slice(7);
      return phone;
    }

    if (userId) {
      showDashboard();
    }

    sendCodeBtn.addEventListener("click", async () => {
      const phone = phoneInput.value.trim();
      if (!/^1\d{10}$/.test(phone)) {
        alert("请输入正确的手机号");
        return;
      }
      sendCodeBtn.textContent = "发送中...";
      try {
        await fetch(`${API_BASE}/auth/send-code`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ phone }),
        });
        let countdown = 60;
        sendCodeBtn.textContent = `${countdown}s`;
        const timer = setInterval(() => {
          countdown--;
          sendCodeBtn.textContent = `${countdown}s`;
          if (countdown <= 0) {
            clearInterval(timer);
            sendCodeBtn.textContent = "获取验证码";
          }
        }, 1000);
      } catch {
        sendCodeBtn.textContent = "获取验证码";
        alert("发送失败，请稍后重试");
      }
    });

    loginBtn.addEventListener("click", async () => {
      const phone = phoneInput.value.trim();
      const code = codeInput.value.trim();
      if (!phone || !code) {
        alert("请输入手机号和验证码");
        return;
      }
      loginBtn.textContent = "登录中...";
      try {
        const res = await fetch(`${API_BASE}/auth/login`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ phone, code }),
        });
        const data = await res.json();
        if (data.success) {
          userId = phone;
          localStorage.setItem("openclaw_userId", userId);
          if (data.token) localStorage.setItem("openclaw_token", data.token);
          showDashboard();
        } else {
          alert(data.message || "登录失败");
        }
      } catch {
        alert("网络错误，请稍后重试");
      }
      loginBtn.textContent = "登录";
    });

    logoutBtn.addEventListener("click", () => {
      localStorage.removeItem("openclaw_userId");
      localStorage.removeItem("openclaw_token");
      userId = "";
      loginScreen.classList.remove("hidden");
      dashScreen.classList.add("hidden");
      logoutBtn.classList.add("hidden");
      navPhone.textContent = "";
    });

    // --- Dashboard ---
    function showDashboard() {
      loginScreen.classList.add("hidden");
      dashScreen.classList.remove("hidden");
      logoutBtn.classList.remove("hidden");
      navPhone.textContent = maskPhone(userId);
      dashPhone.textContent = maskPhone(userId);
      fetchBalance();
      fetchAgentStatus();
      fetchChannelStatus();
      fetchUsage();
    }

    async function fetchBalance() {
      try {
        const res = await fetch(`${API_BASE}/user/balance?userId=${encodeURIComponent(userId)}`);
        const data = await res.json();
        if (data.success && data.data) {
          dashBalance.textContent = `¥${Number(data.data.balance).toFixed(2)}`;
        }
      } catch { /* silent */ }
    }

    async function fetchAgentStatus() {
      const badge = document.getElementById("agent-status-badge")!;
      const text = document.getElementById("agent-status-text")!;
      try {
        const res = await fetch(`${API_BASE}/agent/status?userId=${encodeURIComponent(userId)}`);
        const data = await res.json();
        if (data.success && data.data?.running) {
          badge.textContent = "运行中";
          badge.className = "text-xs px-2 py-0.5 rounded-full bg-green-500/20 text-green-400";
          text.textContent = "你的 AI 智能体正在运行，可以正常收发消息。";
        } else {
          badge.textContent = "未启动";
          badge.className = "text-xs px-2 py-0.5 rounded-full bg-yellow-500/20 text-yellow-400";
          text.textContent = "充值 ¥6 即可激活 AI 智能体（含 Tokens + 免费部署），无需手动操作。";
        }
      } catch {
        badge.textContent = "未知";
        badge.className = "text-xs px-2 py-0.5 rounded-full bg-gray-500/20 text-gray-400";
        text.textContent = "无法获取状态，请稍后刷新。";
      }
    }

    async function fetchChannelStatus() {
      try {
        const res = await fetch(`${API_BASE}/channels/status?userId=${encodeURIComponent(userId)}`);
        const data = await res.json();
        if (data.success && data.data) {
          for (const [channel, info] of Object.entries(data.data) as [string, { active: boolean }][]) {
            const btn = document.querySelector(`.channel-toggle[data-channel="${channel}"]`);
            if (btn && info.active) {
              btn.classList.add("active");
              btn.textContent = "已开启";
            }
          }
        }
      } catch { /* silent */ }
    }

    async function fetchUsage() {
      try {
        const res = await fetch(`${API_BASE}/user/consumption-history?userId=${encodeURIComponent(userId)}&page=1&pageSize=5`);
        const data = await res.json();
        const list = document.getElementById("usage-list")!;
        if (data.success && data.data?.records?.length) {
          list.innerHTML = "";
          data.data.records.forEach((r: { description: string; amount: number; createdAt: string }) => {
            const item = document.createElement("div");
            item.className = "flex items-center justify-between text-sm py-2 border-b border-white/5";
            item.innerHTML = `
              <div>
                <span class="text-gray-300">${r.description || "AI 对话"}</span>
                <span class="text-xs text-gray-500 ml-2">${new Date(r.createdAt).toLocaleDateString()}</span>
              </div>
              <span class="text-red-400 text-xs">-¥${Number(r.amount).toFixed(2)}</span>
            `;
            list.appendChild(item);
          });
        }
      } catch { /* silent */ }
    }

    // --- Quick Recharge ---
    document.querySelectorAll(".quick-amt").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".quick-amt").forEach(b => b.classList.remove("selected"));
        btn.classList.add("selected");
        selectedAmount = Number((btn as HTMLElement).dataset.amount);
      });
    });

    function doPayment(method: string) {
      if (!userId) return;
      const params = new URLSearchParams({
        amount: String(selectedAmount),
        paymentMethod: method,
        userId,
        returnUrl: RETURN_URL,
      });
      window.location.href = `${PAYMENT_DOMAIN}/orderConfirm?${params.toString()}`;
    }

    document.getElementById("pay-alipay")?.addEventListener("click", () => doPayment("alipay"));
    document.getElementById("pay-wechat")?.addEventListener("click", () => doPayment("wechat"));
    document.getElementById("recharge-btn")?.addEventListener("click", () => {
      document.querySelector(".quick-amt.selected")?.scrollIntoView({ behavior: "smooth", block: "center" });
    });

    // --- Environment detection for payment ---
    const ua = navigator.userAgent;
    const isWeChat = /MicroMessenger/i.test(ua);
    const isMobile = /mobile|android|iphone|ipad|phone/i.test(ua);
    if (isWeChat) {
      (document.getElementById("pay-alipay") as HTMLElement).style.display = "none";
    } else if (isMobile) {
      (document.getElementById("pay-wechat") as HTMLElement).style.display = "none";
    }

    // --- Channel Config Modal ---
    const modal = document.getElementById("channel-modal")!;
    const modalTitle = document.getElementById("modal-title")!;
    const modalBody = document.getElementById("modal-body")!;
    const modalClose = document.getElementById("modal-close")!;
    const modalCancel = document.getElementById("modal-cancel")!;
    const modalSave = document.getElementById("modal-save")!;
    let currentChannel = "";

    document.querySelectorAll(".channel-toggle").forEach(btn => {
      btn.addEventListener("click", () => {
        currentChannel = (btn as HTMLElement).dataset.channel || "";
        const config = channelConfigs[currentChannel];
        if (!config) return;

        modalTitle.textContent = config.title;
        modalBody.innerHTML = config.fields.map(f => `
          <div>
            <label class="block text-xs text-gray-400 mb-1">${f.label}</label>
            <input
              type="text"
              data-key="${f.key}"
              placeholder="${f.placeholder}"
              class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500"
            />
          </div>
        `).join("");

        modal.classList.remove("hidden");
      });
    });

    function closeModal() { modal.classList.add("hidden"); }
    modalClose.addEventListener("click", closeModal);
    modalCancel.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

    modalSave.addEventListener("click", async () => {
      const fields: Record<string, string> = {};
      modalBody.querySelectorAll("input").forEach(input => {
        fields[(input as HTMLElement).dataset.key || ""] = (input as HTMLInputElement).value.trim();
      });

      const hasEmpty = Object.values(fields).some(v => !v);
      if (hasEmpty) {
        alert("请填写所有字段");
        return;
      }

      modalSave.textContent = "保存中...";
      try {
        const res = await fetch(`${API_BASE}/channels/configure`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ userId, channel: currentChannel, config: fields }),
        });
        const data = await res.json();
        if (data.success) {
          const btn = document.querySelector(`.channel-toggle[data-channel="${currentChannel}"]`);
          if (btn) {
            btn.classList.add("active");
            btn.textContent = "已开启";
          }
          closeModal();
        } else {
          alert(data.message || "配置失败");
        }
      } catch {
        alert("网络错误，请稍后重试");
      }
      modalSave.textContent = "保存";
    });
  </script>

</BaseLayout>
