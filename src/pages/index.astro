---
import BaseLayout from "../components/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="OpenClaw - 让普通人也能用上 AI 智能体" description="一键安装 AI 智能体，连接微信、飞书、钉钉等平台，无需编程经验，开箱即用。" lang="zh-CN">
  <Navbar lang="zh" />

  <!-- Hero -->
  <section class="hero-gradient pt-32 pb-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
        让 AI 真正<span class="text-indigo-400">为你工作</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        无需安装、无需配置。注册充值后，在网页上点几下就能连接微信、飞书、钉钉等平台。
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-8">
        <a href="/dashboard/" class="px-8 py-3 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white font-semibold transition-colors text-lg">
          免费注册
        </a>
        <a href="/cases/" class="px-8 py-3 border border-white/20 hover:border-white/40 rounded-lg text-gray-300 hover:text-white font-semibold transition-colors text-lg">
          查看案例
        </a>
      </div>

      <p class="text-sm text-gray-500">¥6 即享 AI Tokens + 免费云端部署，无需技术背景</p>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-4 bg-gray-900/50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">为什么选择 OpenClaw</h2>
      <div class="card-grid">
        <div class="feature-card">
          <div class="text-3xl mb-3">🚀</div>
          <h3 class="text-lg font-semibold mb-2">一键安装</h3>
          <p class="text-gray-400 text-sm">一条命令搞定安装，支持 macOS、Linux、Windows。不需要 Docker，不需要配环境。</p>
        </div>
        <div class="feature-card">
          <div class="text-3xl mb-3">💬</div>
          <h3 class="text-lg font-semibold mb-2">全平台消息</h3>
          <p class="text-gray-400 text-sm">微信、企业微信、飞书、钉钉、Telegram、WhatsApp、Discord —— 一个智能体，所有平台。</p>
        </div>
        <div class="feature-card">
          <div class="text-3xl mb-3">🧠</div>
          <h3 class="text-lg font-semibold mb-2">多种 AI 模型</h3>
          <p class="text-gray-400 text-sm">支持 Claude、GPT-4、Gemini、DeepSeek、通义千问等主流模型，随时切换。</p>
        </div>
        <div class="feature-card">
          <div class="text-3xl mb-3">🔧</div>
          <h3 class="text-lg font-semibold mb-2">能做事的 AI</h3>
          <p class="text-gray-400 text-sm">不只是聊天。发邮件、管日历、查天气、控制智能家居 —— AI 真正帮你干活。</p>
        </div>
        <div class="feature-card">
          <div class="text-3xl mb-3">🏠</div>
          <h3 class="text-lg font-semibold mb-2">智能家居</h3>
          <p class="text-gray-400 text-sm">对接 Home Assistant，用自然语言控制灯光、空调、窗帘，告别复杂的自动化配置。</p>
        </div>
        <div class="feature-card">
          <div class="text-3xl mb-3">🔒</div>
          <h3 class="text-lg font-semibold mb-2">隐私安全</h3>
          <p class="text-gray-400 text-sm">数据本地存储，自托管部署。你的聊天记录不经过第三方，完全掌控自己的数据。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Supported Platforms -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4">支持的平台与服务</h2>
      <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">连接国内外主流聊天平台和 AI 模型</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {[
          { name: "微信", icon: "💚" },
          { name: "企业微信", icon: "🏢" },
          { name: "飞书", icon: "🐦" },
          { name: "钉钉", icon: "📌" },
          { name: "Telegram", icon: "✈️" },
          { name: "WhatsApp", icon: "📱" },
          { name: "Discord", icon: "🎮" },
          { name: "Slack", icon: "💼" },
          { name: "Signal", icon: "🔐" },
          { name: "iMessage", icon: "🍎" },
          { name: "Teams", icon: "👥" },
          { name: "Matrix", icon: "🔗" },
        ].map((item) => (
          <div class="flex flex-col items-center gap-2 p-4 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <span class="text-2xl">{item.icon}</span>
            <span class="text-xs text-gray-300">{item.name}</span>
          </div>
        ))}
      </div>

      <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {[
          { name: "Claude", icon: "🟣" },
          { name: "GPT-4", icon: "🟢" },
          { name: "Gemini", icon: "🔵" },
          { name: "DeepSeek", icon: "🌊" },
          { name: "Grok", icon: "⚡" },
          { name: "Ollama", icon: "🦙" },
        ].map((item) => (
          <div class="flex flex-col items-center gap-2 p-4 rounded-lg bg-white/5 hover:bg-white/10 transition-colors">
            <span class="text-2xl">{item.icon}</span>
            <span class="text-xs text-gray-300">{item.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-indigo-600/10">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">准备好了吗？</h2>
      <p class="text-gray-300 mb-8">注册充值 ¥6，即得 AI Tokens + 免费部署，立刻拥有你的 AI 智能体。</p>
      <a href="/dashboard/" class="inline-block px-8 py-3 bg-indigo-600 hover:bg-indigo-500 rounded-lg text-white font-semibold transition-colors text-lg">
        免费注册
      </a>
    </div>
  </section>

  <Footer lang="zh" />
</BaseLayout>
